// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────
model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String?
  password   String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  projectMemberships ProjectMember[]
  createdProjects    Project[]       @relation("ProjectCreator")
  assignedTasks      Task[]          @relation("TaskAssignee")
  reportedTasks      Task[]          @relation("TaskReporter")
  sentInvites        ProjectInvite[] @relation("InviteSender")
  emailVerificationToken EmailVerificationToken?
}

// ─────────────────────────────────────────────
// PROJECT
// self-referential: a project can have sub-projects via parentId
// creator is automatically ADMIN via ProjectMember
// ─────────────────────────────────────────────
model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  parentId    String?  // null = top-level project
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User            @relation("ProjectCreator", fields: [createdById], references: [id])
  parent      Project?        @relation("SubProjects", fields: [parentId], references: [id], onDelete: Cascade)
  subProjects Project[]       @relation("SubProjects")
  members     ProjectMember[]
  invites     ProjectInvite[]
  tasks       Task[]
}

// ─────────────────────────────────────────────
// PROJECT MEMBER
// role = ADMIN | MEMBER | VIEWER
// creator is seeded as ADMIN when project is created
// ─────────────────────────────────────────────
model ProjectMember {
  id        String      @id @default(uuid())
  projectId String
  userId    String
  role      ProjectRole @default(MEMBER)
  createdAt DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

// ─────────────────────────────────────────────
// PROJECT INVITE
// tokenHash = SHA-256 of the raw token sent in email
// ─────────────────────────────────────────────
model ProjectInvite {
  id          String       @id @default(uuid())
  projectId   String
  email       String
  role        ProjectRole  @default(MEMBER)
  tokenHash   String       @unique
  status      InviteStatus @default(PENDING)
  invitedById String
  expiresAt   DateTime
  createdAt   DateTime     @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invitedBy User    @relation("InviteSender", fields: [invitedById], references: [id])

  @@index([tokenHash])
  @@index([email])
}

// ─────────────────────────────────────────────
// TASK
// ─────────────────────────────────────────────
model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  projectId   String
  assigneeId  String?
  reporterId  String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter User    @relation("TaskReporter", fields: [reporterId], references: [id])
}

// ─────────────────────────────────────────────
// EMAIL VERIFICATION TOKEN
// ─────────────────────────────────────────────
model EmailVerificationToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────
enum ProjectRole {
  ADMIN
  MEMBER
  VIEWER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}
