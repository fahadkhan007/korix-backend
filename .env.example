# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=8000
FRONTEND_CLIENT_URL=http://localhost:5173
BACKEND_CLIENT_URL=http://localhost:8000

# ─────────────────────────────────────────────
# Database (overridden by docker-compose to use
# the 'postgres' service hostname)
# ─────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=korix
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/korix

# ─────────────────────────────────────────────
# Redis (overridden by docker-compose)
# ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─────────────────────────────────────────────
# JWT Secrets  (replace with strong random values)
# ─────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# ─────────────────────────────────────────────
# Email (Resend)
# ─────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here

# ─────────────────────────────────────────────
# Email (SMTP / Brevo)
# ─────────────────────────────────────────────
SMTP_KEY=your_smtp_key_here
SMTP_LOGIN=your_smtp_login_here
SMTP_FROM=your_smtp_from_here
SMTP_SERVER=smtp-relay.brevo.com
SMTP_PORT=587
